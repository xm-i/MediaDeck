<local:FolderGroupExecutionConfigViewUserControl
	x:Class="MediaDeck.MediaItemTypes.FolderGroup.Views.FolderGroupExecutionConfigView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.MediaItemTypes.FolderGroup.Views"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:enum="using:MediaDeck.Composition.Enum"
	mc:Ignorable="d">

	<StackPanel Spacing="10" Margin="0,10,0,0">
		<ComboBox Header="実行方法"
			HorizontalAlignment="Stretch"
			ItemsSource="{x:Bind ViewModel.ExecutionTypeConditions, Mode=OneWay}"
			SelectedItem="{x:Bind ViewModel.ExecutionType.Value, Mode=TwoWay}">
		</ComboBox>

		<!-- 外部プログラム設定 -->
		<Grid ColumnDefinitions="*,Auto">
			<TextBox Grid.Column="0"
				Margin="0,0,8,0"
				Text="{x:Bind ViewModel.Path.Value, Mode=TwoWay}"
				PlaceholderText="C:\Programs\MPC-BE\mpc-be64.exe"
				Header="実行ファイルパス" />

			<TextBox Grid.Column="1"
				Width="200"
				Text="{x:Bind ViewModel.Args.Value, Mode=TwoWay}"
				PlaceholderText="/fullscreen"
				Header="起動引数" />
		</Grid>
        
		<TextBlock Text="MediaDeckのライブラリ画面でこのフォルダを開きます。" 
			Style="{StaticResource CaptionTextBlockStyle}"
			Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
	</StackPanel>
</local:FolderGroupExecutionConfigViewUserControl>
