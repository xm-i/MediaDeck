<?xml version="1.0" encoding="utf-8"?>
<UserControl
	x:Class="MediaDeck.Views.Tools.DuplicateDetectorContent"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views.Tools"
	xmlns:fvm="using:MediaDeck.Composition.Interfaces.FileTypes.ViewModels"
	xmlns:tools="using:MediaDeck.Core.Models.Tools"
	xmlns:controls="using:CommunityToolkit.WinUI.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">
	<Grid Padding="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- 検出設定 -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
			<ComboBox 
				ItemsSource="{x:Bind ViewModel.HashTypeList}"
				SelectedItem="{x:Bind ViewModel.SelectedHashType.Value, Mode=TwoWay}"
				DisplayMemberPath="DisplayString"
				Width="200"/>
			<Button 
				Content="Start Detection" 
				Command="{x:Bind ViewModel.DetectCommand}"/>
			<ProgressRing 
				IsActive="{x:Bind ViewModel.IsDetecting.Value, Mode=OneWay}" 
				Width="24" 
				Height="24"/>
		</StackPanel>

		<!-- メインコンテンツ -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="16"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- 重複グループリスト -->
			<Grid Grid.Column="0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0" Text="Duplicate Groups" FontWeight="Bold" Margin="0,0,0,8"/>
				<ListView 
					Grid.Row="1"
					ItemsSource="{x:Bind ViewModel.DuplicateGroups, Mode=OneWay}"
					SelectedItem="{x:Bind ViewModel.SelectedGroup.Value, Mode=TwoWay}"
					SelectionMode="Single">
					<ListView.ItemTemplate>
						<DataTemplate x:DataType="tools:DuplicateFileGroup">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="{x:Bind Files.Count}"/>
								<TextBlock Grid.Column="1" Text="files"/>
								<TextBlock Grid.Column="2" Text="-"/>
								<TextBlock Grid.Column="3" Text="{x:Bind RepresentativeFileName}" TextTrimming="CharacterEllipsis"/>
							</Grid>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>
			</Grid>

			<!-- 区切り -->
			<controls:GridSplitter 
				Grid.Column="1" 
				Width="16" 
				HorizontalAlignment="Center"
				Background="Transparent"/>

			<!-- 選択グループのファイルリスト -->
			<Grid Grid.Column="2">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0" Text="File List" FontWeight="Bold" Margin="0,0,0,8"/>
				<!-- ヘッダー行 -->
				<Grid Grid.Row="1" Background="{ThemeResource SubtleFillColorSecondaryBrush}" Padding="4,8">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="50"/>
						<ColumnDefinition Width="*" MinWidth="150"/>
						<ColumnDefinition Width="100"/>
						<ColumnDefinition Width="60"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="120"/>
						<ColumnDefinition Width="60"/>
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0" Text="" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="1" Text="ファイルパス" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="2" Text="タグ" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="3" Text="再生回数" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="4" Text="評価" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="5" Text="作成日時" FontWeight="SemiBold"/>
					<TextBlock Grid.Column="6" Text="" FontWeight="SemiBold"/>
				</Grid>
				<ListView 
					Grid.Row="2"
					ItemsSource="{x:Bind ViewModel.SelectedGroupFiles.Value, Mode=OneWay}"
					SelectedItem="{x:Bind ViewModel.SelectedFile.Value, Mode=TwoWay}"
					SelectionMode="Single">
					<ListView.ItemContainerStyle>
						<Style TargetType="ListViewItem">
							<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
							<Setter Property="Padding" Value="0"/>
							<Setter Property="Margin" Value="0"/>
							<Setter Property="MinHeight" Value="0"/>
						</Style>
					</ListView.ItemContainerStyle>
					<ListView.ItemTemplate>
						<DataTemplate x:DataType="fvm:IFileViewModel">
							<Grid Padding="4,4">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="50"/>
									<ColumnDefinition Width="*" MinWidth="150"/>
									<ColumnDefinition Width="100"/>
									<ColumnDefinition Width="60"/>
									<ColumnDefinition Width="40"/>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="60"/>
								</Grid.ColumnDefinitions>
								<Image Grid.Column="0" Stretch="Uniform" Height="40" Source="{x:Bind ThumbnailFilePath.Value, Mode=OneWay}"/>
								<TextBlock Grid.Column="1" Text="{x:Bind FilePath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="2" Text="{x:Bind FileModel.Tags, Converter={StaticResource TagListConverter}}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="3" Text="{x:Bind FileModel.UsageCount}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
								<TextBlock Grid.Column="4" Text="{x:Bind FileModel.Rate}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
								<TextBlock Grid.Column="5" Text="{x:Bind FileModel.CreationTime}" VerticalAlignment="Center"/>
								<StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
									<Button 
										Click="OnOpenFileClick"
										Padding="4"
										Background="Transparent"
										BorderThickness="0">
										<FontIcon Glyph="&#xE8E5;" FontSize="12"/>
										<ToolTipService.ToolTip>
											<ToolTip Content="Open File"/>
										</ToolTipService.ToolTip>
									</Button>
									<Button 
										Click="OnShowInExplorerClick"
										Padding="4"
										Background="Transparent"
										BorderThickness="0">
										<FontIcon Glyph="&#xE8B7;" FontSize="12"/>
										<ToolTipService.ToolTip>
											<ToolTip Content="Show in Explorer"/>
										</ToolTipService.ToolTip>
									</Button>
								</StackPanel>
							</Grid>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>
			</Grid>
		</Grid>

		<!-- ステータスバー -->
		<StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,16,0,0">
			<TextBlock>
				<Run Text="Duplicate Groups:"/>
				<Run Text="{x:Bind ViewModel.DuplicateGroupCount.Value, Mode=OneWay}"/>
			</TextBlock>
			<TextBlock>
				<Run Text="Total Duplicate Files:"/>
				<Run Text="{x:Bind ViewModel.DuplicateFileCount.Value, Mode=OneWay}"/>
			</TextBlock>
		</StackPanel>
	</Grid>
</UserControl>
