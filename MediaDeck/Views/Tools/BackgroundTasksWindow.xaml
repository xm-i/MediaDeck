<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="MediaDeck.Views.Tools.BackgroundTasksWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Title="BackgroundTasks" >
	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop/>
	</Window.SystemBackdrop>
	<Grid Background="Transparent"
		Loaded="Window_Loaded" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- カスタムタイトルバー -->
		<Grid x:Name="AppTitleBar" Grid.Row="0" Height="32"
			Background="{ThemeResource TitleBarBackgroundBrush}"
			Padding="12,0,0,0"
			VerticalAlignment="Top" >
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Image Source="/Assets/Square44x44Logo.scale-200.png" Width="16" Height="16" Margin="4,0,8,0" />
				<TextBlock Text="{x:Bind Title}" FontSize="12" VerticalAlignment="Center" />
			</StackPanel>
		</Grid>

		<StackPanel Grid.Row="1" >
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Row="0"
				Grid.Column="0"
				Text="Update file status" />
			<TextBlock Grid.Row="1"
				Grid.Column="0" >
				<Run Text="{x:Bind ViewModel.FileStatusUpdaterCompletedCount.Value, Mode=OneWay}" />
				<Run Text="/" />
				<Run Text="{x:Bind ViewModel.FileStatusUpdaterTargetCount.Value, Mode=OneWay}" />
			</TextBlock>
		</Grid>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Row="0"
				Grid.Column="0"
				Text="Update file hash" />
			<TextBlock Grid.Row="1"
				Grid.Column="0" >
				<Run Text="{x:Bind ViewModel.UpdateFileHashBackgroundServiceCompletedCount.Value, Mode=OneWay}" />
				<Run Text="/" />
				<Run Text="{x:Bind ViewModel.UpdateFileHashBackgroundServiceTargetCount.Value, Mode=OneWay}" />
			</TextBlock>
		</Grid>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Row="0"
				Grid.Column="0"
				Text="Update full hash" />
			<TextBlock Grid.Row="1"
				Grid.Column="0" >
				<Run Text="{x:Bind ViewModel.FullHashUpdaterCompletedCount.Value, Mode=OneWay}" />
				<Run Text="/" />
				<Run Text="{x:Bind ViewModel.FullHashUpdaterTargetCount.Value, Mode=OneWay}" />
			</TextBlock>
		</Grid>
	</StackPanel>
	</Grid>
</Window>