<local:StatusBarPaneUserControl
	x:Class="MediaDeck.Views.Panes.StatusPanes.StatusBarPane"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views.Panes.StatusPanes"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewmodels="using:MediaDeck.ViewModels"
	xmlns:viewerpanesVm="using:MediaDeck.ViewModels.Panes.ViewerPanes"
	xmlns:controls="using:CommunityToolkit.WinUI.Controls"
	mc:Ignorable="d" >

	<Grid BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
		BorderThickness="0,1,0,0"
		Padding="16,0"
		Height="36"
		ColumnSpacing="8" >
		<Grid ColumnSpacing="20">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<StackPanel Orientation="Horizontal"
				Grid.Column="0"
				VerticalAlignment="Center"
				Spacing="16" >
				<local:BackgroundTasksStatusIndicator
					ViewModel="{x:Bind ViewModel.BackgroundTasks, Mode=OneWay}" />
				<StackPanel Orientation="Horizontal"
					VerticalAlignment="Center"
					Spacing="8" >
					<TextBlock VerticalAlignment="Center"
						Style="{StaticResource CaptionTextBlockStyle}" >
						<Run Text="Count: " />
						<Run Text="{x:Bind ViewModel.MediaContentLibrary.Files.Count, Mode=OneWay}" />
					</TextBlock>
					<TextBlock VerticalAlignment="Center"
						Style="{StaticResource CaptionTextBlockStyle}"
						Visibility="{x:Bind ViewModel.MediaContentLibrary.SearchElapsedMilliseconds.Value, Mode=OneWay, Converter={StaticResource NullToCollapseConverter}}" >
						<Run Text="  /  Search: " />
						<Run Text="{x:Bind ViewModel.MediaContentLibrary.SearchElapsedMilliseconds.Value, Mode=OneWay}" />
						<Run Text=" ms" />
					</TextBlock>
				</StackPanel>
			</StackPanel>

			<Grid Grid.Row="1"/>

			<controls:Segmented x:Name="ViewerModeSegmented"
				Grid.Column="2"
				SelectionMode="Single"
				ItemsSource="{x:Bind ViewModel.ViewerSelector.ViewerPaneViewModels, Mode=OneWay}"
				SelectedItem="{x:Bind ViewModel.ViewerSelector.SelectedViewerPane.Value, Mode=OneWay}"
				SelectionChanged="ViewerModeSegmented_SelectionChanged" >
				<controls:Segmented.ItemTemplate>
					<DataTemplate x:DataType="viewerpanesVm:ViewerPaneViewModelBase" >
						<FontIcon Glyph="{x:Bind IconGlyph}"
								FontSize="14" />
					</DataTemplate>
				</controls:Segmented.ItemTemplate>
			</controls:Segmented>

				<StackPanel Grid.Column="3"
					Orientation="Horizontal"
					VerticalAlignment="Center"
					Spacing="8" >
					<ToggleButton MinWidth="96"
						Height="30"
						IsChecked="{x:Bind ViewModel.ShowOverlay.Value, Mode=TwoWay}" >
						<StackPanel Orientation="Horizontal" Spacing="6" >
							<FontIcon Glyph="&#xE71E;" FontSize="14" />
							<TextBlock Text="Overlay" VerticalAlignment="Center" />
						</StackPanel>
					</ToggleButton>
					<ToggleButton MinWidth="80"
						Height="30"
						IsChecked="{x:Bind ViewModel.ShowInfo.Value, Mode=TwoWay}" >
						<StackPanel Orientation="Horizontal" Spacing="6" >
							<FontIcon Glyph="&#xE946;" FontSize="14" />
							<TextBlock Text="Info" VerticalAlignment="Center" />
						</StackPanel>
					</ToggleButton>
				</StackPanel>

				<StackPanel Grid.Column="4"
				Orientation="Horizontal"
				VerticalAlignment="Center"
				Spacing="12" >
				<!-- アイコン: 小 -->
				<Button Command="{x:Bind ViewModel.ZoomOutCommand, Mode=OneWay}"
					Padding="4"
					Background="Transparent"
					BorderThickness="0"
					VerticalAlignment="Center" >
					<FontIcon Glyph="&#xE799;"
						FontSize="12"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
				</Button>

				<Slider x:Name="ItemSizeSlider"
					TickFrequency="50"
					TickPlacement="None"
					StepFrequency="10"
					Minimum="50"
					Maximum="500"
					Width="200"
					VerticalAlignment="Center"
					Margin="0,0,0,0"
					Value="{x:Bind ViewModel.ItemSize.Value, Mode=TwoWay}" />

				<!-- アイコン: 大 -->
				<Button Command="{x:Bind ViewModel.ZoomInCommand, Mode=OneWay}"
					Padding="4"
					Background="Transparent"
					BorderThickness="0"
					VerticalAlignment="Center" >
					<FontIcon Glyph="&#xE799;"
						FontSize="20"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
				</Button>
			</StackPanel>
		</Grid>
	</Grid>
</local:StatusBarPaneUserControl>
