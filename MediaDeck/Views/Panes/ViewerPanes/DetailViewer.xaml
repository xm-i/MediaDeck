<?xml version="1.0" encoding="utf-8" ?>
<local:ViewerPaneBase x:Class="MediaDeck.Views.Panes.ViewerPanes.DetailViewer"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views.Panes.ViewerPanes"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:controls="using:CommunityToolkit.WinUI.Controls"
	xmlns:vmIf="using:MediaDeck.Composition.Interfaces.MediaItemTypes.ViewModels"
	xmlns:viewerpanes="using:MediaDeck.ViewModels.Panes.ViewerPanes"
	mc:Ignorable="d" >
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="auto" />
		</Grid.RowDefinitions>
		<controls:TokenizingTextBox Grid.Row="0"
			RelativePanel.AlignVerticalCenterWithPanel="True"
			ItemsSource="{x:Bind ViewModel.MediaContentLibraryViewModel.SearchConditions ,Mode=OneWay}"
			SuggestedItemsSource="{x:Bind ViewModel.MediaContentLibraryViewModel.FilteredSearchConditionCandidates,Mode=OneWay}"
			TextChanged="TokenizingTextBox_TextChanged"
			TokenItemAdding="TokenizingTextBox_TokenItemAdding"
			TokenItemRemoving="TokenizingTextBox_TokenItemRemoving" >
			<controls:TokenizingTextBox.TokenItemTemplate>
				<DataTemplate x:DataType="viewerpanes:SearchConditionViewModel" >
					<TextBlock Text="{x:Bind DisplayText}" />
				</DataTemplate>
			</controls:TokenizingTextBox.TokenItemTemplate>
			<controls:TokenizingTextBox.SuggestedItemTemplate>
				<DataTemplate x:DataType="viewerpanes:SearchConditionViewModel" >
					<TextBlock Text="{x:Bind DisplayText}" />
				</DataTemplate>
			</controls:TokenizingTextBox.SuggestedItemTemplate>
		</controls:TokenizingTextBox>
		<Grid Grid.Row="1" >
			<ContentControl
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				HorizontalContentAlignment="Stretch"
				VerticalContentAlignment="Stretch"
				Content="{x:Bind ViewModel.DetailViewerViewModel.SelectedFile.Value, Mode=OneWay}"
				ContentTemplateSelector="{StaticResource MediaItemDetailTplSel}" />
		</Grid>
		<ListView x:Name="List"
			Margin="10"
			Grid.Row="2"
			ItemsSource="{x:Bind ViewModel.MediaContentLibraryViewModel.Files, Mode=OneWay}"
			SelectedItem="{x:Bind ViewModel.MediaContentLibraryViewModel.SelectedFile.Value, Mode=TwoWay}"
			SelectionMode="Single"
			SelectionChanged="List_SelectionChanged"
			ScrollViewer.HorizontalScrollMode="Auto"
			ScrollViewer.HorizontalScrollBarVisibility="Auto" >
			<ListView.ItemsPanel>
				<ItemsPanelTemplate>
					<ItemsStackPanel Orientation="Horizontal" />
				</ItemsPanelTemplate>
			</ListView.ItemsPanel>
			<ListView.ItemTemplate>
				<DataTemplate x:DataType="vmIf:IMediaItemViewModel" >
					<Grid DoubleTapped="File_DoubleTapped" >
						<ContentControl
							Content="{x:Bind}"
							ContentTemplateSelector="{StaticResource MediaItemThumbnailControlTplSel}"
							Height="{Binding DataContext.ItemSize.Value, Mode=OneWay, ElementName=List}"
							HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
						<Grid Opacity="0.7"
							Background="DarkGray"
							Visibility="{x:Bind Exists, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
					</Grid>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>
	</Grid>
</local:ViewerPaneBase>