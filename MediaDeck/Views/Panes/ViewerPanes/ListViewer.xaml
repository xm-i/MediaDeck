<?xml version="1.0" encoding="utf-8" ?>
<local:ViewerPaneBase x:Class="MediaDeck.Views.Panes.ViewerPanes.ListViewer"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views.Panes.ViewerPanes"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vmIf="using:MediaDeck.Composition.Interfaces.MediaItemTypes.ViewModels"
	mc:Ignorable="d" >
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<local:SearchConditionManagerView Grid.Row="0" ViewModel="{x:Bind ViewModel.SearchConditionManagerViewModel, Mode=OneWay}" />
		<!-- ヘッダー行 -->
		<Grid Grid.Row="1"
			Background="{ThemeResource SubtleFillColorSecondaryBrush}"
			Padding="4,8" >
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="60" />
				<ColumnDefinition Width="*"
					MinWidth="200" />
				<ColumnDefinition Width="100" />
				<ColumnDefinition Width="100" />
				<ColumnDefinition Width="150" />
				<ColumnDefinition Width="60" />
			</Grid.ColumnDefinitions>
			<TextBlock Grid.Column="0"
				Text=""
				FontWeight="SemiBold" />
			<TextBlock Grid.Column="1"
				Text="ファイル名"
				FontWeight="SemiBold" />
			<TextBlock Grid.Column="2"
				Text="解像度"
				FontWeight="SemiBold" />
			<TextBlock Grid.Column="3"
				Text="サイズ"
				FontWeight="SemiBold" />
			<TextBlock Grid.Column="4"
				Text="作成日時"
				FontWeight="SemiBold" />
			<TextBlock Grid.Column="5"
				Text="評価"
				FontWeight="SemiBold" />
		</Grid>
		<ListBox x:Name="List"
			Grid.Row="2"
			ItemsSource="{x:Bind ViewModel.MediaContentLibraryViewModel.Files, Mode=OneWay}"
			SelectedItem="{x:Bind ViewModel.MediaContentLibraryViewModel.SelectedFile.Value, Mode=TwoWay}"
			SelectionMode="Extended"
			SelectionChanged="List_SelectionChanged"
			RightTapped="List_RightTapped"
			ScrollViewer.VerticalScrollMode="Auto"
			ScrollViewer.VerticalScrollBarVisibility="Auto" >
			<ListBox.ItemContainerStyle>
				<Style TargetType="ListBoxItem" >
					<Setter Property="HorizontalContentAlignment"
						Value="Stretch" />
					<Setter Property="VerticalContentAlignment"
						Value="Top" />
					<Setter Property="Padding"
						Value="0" />
					<Setter Property="Margin"
						Value="0" />
					<Setter Property="MinHeight"
						Value="0" />
				</Style>
			</ListBox.ItemContainerStyle>
			<ListBox.ItemsPanel>
				<ItemsPanelTemplate>
					<ItemsStackPanel />
				</ItemsPanelTemplate>
			</ListBox.ItemsPanel>
			<ListBox.Resources>
				<MenuFlyout x:Key="FileContextMenu" >
					<MenuFlyoutItem Text="Recreate Thumbnail"
						Click="MenuFlyoutItem_Click"
						Tag="RecreateThumbnail" />
					<MenuFlyoutItem Text="Remove File"
						Click="MenuFlyoutItem_Click"
						Tag="RemoveFile" />
					<MenuFlyoutItem Text="Open Folder"
						Click="MenuFlyoutItem_Click"
						Tag="OpenFolder" />
				</MenuFlyout>
			</ListBox.Resources>
			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="vmIf:IMediaItemViewModel" >
					<Grid DoubleTapped="File_DoubleTapped"
						Height="Auto" >
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"
								MinWidth="60" />
							<ColumnDefinition Width="*"
								MinWidth="200" />
							<ColumnDefinition Width="100" />
							<ColumnDefinition Width="100" />
							<ColumnDefinition Width="150" />
							<ColumnDefinition Width="60" />
						</Grid.ColumnDefinitions>
						<ContentControl Grid.Column="0" Margin="4"
							Content="{x:Bind}"
							ContentTemplateSelector="{StaticResource MediaItemThumbnailControlTplSel}"
							Height="{Binding DataContext.ItemSize.Value, Mode=OneWay, ElementName=List}"
							Width="{Binding DataContext.ItemSize.Value, Mode=OneWay, ElementName=List}"
							HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
						<TextBlock Grid.Column="1"
							Text="{x:Bind FilePath}"
							VerticalAlignment="Center"
							TextTrimming="CharacterEllipsis" />
						<TextBlock Grid.Column="2"
							Text="{x:Bind FileModel.Resolution}"
							VerticalAlignment="Center" />
						<TextBlock Grid.Column="3"
							Text="{x:Bind FileModel.FileSize, Converter={StaticResource FileSizeConverter}}"
							VerticalAlignment="Center" />
						<TextBlock Grid.Column="4"
							Text="{x:Bind FileModel.CreationTime}"
							VerticalAlignment="Center" />
						<TextBlock Grid.Column="5"
							Text="{x:Bind FileModel.Rate}"
							VerticalAlignment="Center" />
						<Grid Grid.ColumnSpan="6"
							Opacity="0.7"
							Background="DarkGray"
							Visibility="{x:Bind Exists, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</local:ViewerPaneBase>