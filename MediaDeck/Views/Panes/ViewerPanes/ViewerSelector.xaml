<?xml version="1.0" encoding="utf-8" ?>
<local:ViewerSelectorUserControl x:Class="MediaDeck.Views.Panes.ViewerPanes.ViewerSelector"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views.Panes.ViewerPanes"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewerpanesVm="using:MediaDeck.ViewModels.Panes.ViewerPanes"
	xmlns:controls="using:CommunityToolkit.WinUI.Controls"
	mc:Ignorable="d" >
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<Grid Grid.Row="0"
			Padding="8,6"
			Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" >
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />

				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<StackPanel Grid.Column="3"
				Orientation="Horizontal"
				Spacing="6" >
				<ComboBox MinWidth="140"
					ItemsSource="{x:Bind ViewModel.SortSelectorViewModel.SortConditions,Mode=OneWay}"
					SelectedItem="{x:Bind ViewModel.SortSelectorViewModel.CurrentCondition.Value,Mode=TwoWay}" >
					<ComboBox.ItemTemplate>
						<DataTemplate x:DataType="viewerpanesVm:SortConditionViewModel" >
							<TextBlock Text="{x:Bind DisplayName.Value}" />
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<ToggleButton
					IsChecked="{x:Bind ViewModel.SortSelectorViewModel.Direction.Value, Mode=TwoWay, Converter={StaticResource ListSortDirectionToBooleanConverter}}" >
					<FontIcon
						Glyph="{x:Bind ViewModel.SortSelectorViewModel.Direction.Value, Mode=OneWay, Converter={StaticResource ListSortDirectionToIconGlyphConverter}}"
						FontSize="14" />
				</ToggleButton>
				<Button Click="Button_Click" >
					<FontIcon Glyph="&#xE713;"
						FontSize="14" />
				</Button>
				<Button Command="{x:Bind ViewModel.RefreshCommand}"
					ToolTipService.ToolTip="更新" >
					<FontIcon Glyph="&#xE72C;"
						FontSize="14" />
				</Button>
			</StackPanel>
		</Grid>
		<controls:SwitchPresenter Grid.Row="1"
			Value="{x:Bind ViewModel.SelectedViewerPane.Value,Mode=OneWay}" >
			<controls:Case Value="{x:Bind ViewModel.WrapViewerViewModel,Mode=OneWay}" >
				<local:WrapViewer ViewModel="{x:Bind ViewModel,Mode=OneWay}" />
			</controls:Case>
			<controls:Case Value="{x:Bind ViewModel.ListViewerViewModel,Mode=OneWay}" >
				<local:ListViewer ViewModel="{x:Bind ViewModel,Mode=OneWay}" />
			</controls:Case>
			<controls:Case Value="{x:Bind ViewModel.DetailViewerViewModel,Mode=OneWay}" >
				<local:DetailViewer ViewModel="{x:Bind ViewModel,Mode=OneWay}" />
			</controls:Case>
			<!-- Mapはちゃんと作るまでコメントアウト
			<controls:Case Value="{x:Bind ViewModel.MapViewerViewModel,Mode=OneWay}" >
				<local:MapViewer ViewModel="{x:Bind ViewModel,Mode=OneWay}" />
			</controls:Case>
			-->
		</controls:SwitchPresenter>

	</Grid>
</local:ViewerSelectorUserControl>