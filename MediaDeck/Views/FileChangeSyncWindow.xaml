<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MediaDeck.Views.FileChangeSyncWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:MediaDeck.Models.Services"
    Title="ファイルの同期確認">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16">
            <TextBlock Text="未処理のファイル変更" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="外部でのファイル移動や削除が検出されました。" Margin="0,4,0,0" Foreground="Gray"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Changes, Mode=OneWay}" Margin="16,0" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="services:FileChangeItem">
                    <Grid Padding="12" BorderThickness="0,0,0,1" BorderBrush="LightGray">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ChangeTypeText}" FontWeight="Bold"/>
                            <TextBlock Text="{x:Bind PathText}" TextWrapping="Wrap" Foreground="Gray" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="反映" Click="ApplyItem_Click" Tag="{x:Bind}" />
                            <Button Content="無視" Click="DiscardItem_Click" Tag="{x:Bind}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16" Spacing="8">
            <Button Content="すべて反映" Command="{x:Bind ViewModel.ApplyAllCommand}" Style="{ThemeResource AccentButtonStyle}" />
            <Button Content="すべて無視" Command="{x:Bind ViewModel.DiscardAllCommand}" />
        </StackPanel>
    </Grid>
</Window>
