<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="MediaDeck.Views.FileChangeSyncWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:services="using:MediaDeck.Core.Services.FileChangeMonitor"
	xmlns:viewmodels="using:MediaDeck.ViewModels"
		Title="ファイルの同期確認" >
	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop/>
	</Window.SystemBackdrop>
	<Grid Background="Transparent"
		Loaded="Window_Loaded" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- カスタムタイトルバー -->
		<Grid x:Name="AppTitleBar" Grid.Row="0" Height="32"
			Background="{ThemeResource TitleBarBackgroundBrush}"
			Padding="12,0,0,0"
			VerticalAlignment="Top" >
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Image Source="/Assets/Square44x44Logo.scale-200.png" Width="16" Height="16" Margin="4,0,8,0" />
				<TextBlock Text="{x:Bind Title}" FontSize="12" VerticalAlignment="Center" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="1" >
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

		<StackPanel Grid.Row="0"
			Margin="16" >
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<StackPanel Grid.Column="0" >
					<TextBlock Text="未処理のファイル変更"
						Style="{ThemeResource TitleTextBlockStyle}" />
					<TextBlock Text="外部でのファイル移動や削除が検出されました。"
						Margin="0,4,0,0"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
				</StackPanel>
				<TextBlock Grid.Column="1"
					VerticalAlignment="Bottom"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}" >
					<Run Text="表示中:" />
					<Run Text="{x:Bind ViewModel.FilteredCount.Value, Mode=OneWay}" />
					<Run Text="件" />
				</TextBlock>
			</Grid>

			<RadioButtons Header="表示フィルター"
				ItemsSource="{x:Bind ViewModel.Filters}"
				SelectedItem="{x:Bind ViewModel.FilterType.Value, Mode=TwoWay}"
				Margin="0,16,0,0"
				MaxColumns="3" >
				<RadioButtons.ItemTemplate>
					<DataTemplate x:DataType="viewmodels:FileChangeFilter" >
						<TextBlock Text="{Binding Converter={StaticResource FileChangeFilterToDisplayNameConverter}}"
							Margin="0,0,16,0" />
					</DataTemplate>
				</RadioButtons.ItemTemplate>
			</RadioButtons>
		</StackPanel>

		<ListView Grid.Row="1"
			ItemsSource="{x:Bind ViewModel.FileChangeItems.Value, Mode=OneWay}"
			Margin="16,0"
			SelectionMode="None" >
			<ListView.ItemTemplate>
				<DataTemplate x:DataType="services:FileChangeItem" >
					<Grid Padding="12"
						BorderThickness="0,0,0,1"
						BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" >
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0"
							VerticalAlignment="Center"
							Spacing="2" >
							<TextBlock Text="{x:Bind ChangeTypeText}"
								FontWeight="Bold"
								Margin="0,0,0,4" />

							<StackPanel Orientation="Horizontal"
								Spacing="4"
								Visibility="{Binding OldPath, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" >
								<TextBlock Text="変更前："
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									FontSize="12"
									Width="60" />
								<TextBlock Text="{x:Bind OldPath}"
									TextWrapping="Wrap"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									FontSize="12" />
							</StackPanel>

							<StackPanel Orientation="Horizontal"
								Spacing="4"
								Visibility="{Binding NewPath, Mode=OneWay, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" >
								<TextBlock Text="変更後："
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									FontSize="12"
									Width="60" />
								<TextBlock Text="{x:Bind NewPath}"
									TextWrapping="Wrap"
									Foreground="Gray"
									FontSize="12" />
							</StackPanel>
						</StackPanel>
						<StackPanel Grid.Column="1"
							Orientation="Horizontal"
							Spacing="8"
							VerticalAlignment="Center" >
							<Button Content="反映"
								Click="ApplyItem_Click"
								Tag="{x:Bind}" />
							<Button Content="無視"
								Click="DiscardItem_Click"
								Tag="{x:Bind}" />
						</StackPanel>
					</Grid>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>

		<StackPanel Grid.Row="2"
			Orientation="Horizontal"
			HorizontalAlignment="Right"
			Margin="16"
			Spacing="8" >
			<Button Content="表示中をすべて反映"
				Command="{x:Bind ViewModel.ApplyAllCommand}"
				Style="{ThemeResource AccentButtonStyle}" />
			<Button Content="表示中をすべて無視"
				Command="{x:Bind ViewModel.DiscardAllCommand}" />
		</StackPanel>
	</Grid>
	</Grid>
</Window>