<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="MediaDeck.Views.Preferences.ConfigWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:config="using:MediaDeck.ViewModels.Preferences.Config"
	mc:Ignorable="d"
	Title="設定" >
	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop/>
	</Window.SystemBackdrop>
	<Grid Background="Transparent"
		Loaded="Window_Loaded" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- カスタムタイトルバー -->
		<Grid x:Name="AppTitleBar" Grid.Row="0" Height="32"
			Background="{ThemeResource TitleBarBackgroundBrush}"
			Padding="12,0,0,0"
			VerticalAlignment="Top" >
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Image Source="/Assets/Square44x44Logo.scale-200.png" Width="16" Height="16" Margin="4,0,8,0" />
				<TextBlock Text="{x:Bind Title}" FontSize="12" VerticalAlignment="Center" />
			</StackPanel>
		</Grid>

		<NavigationView x:Name="SettingsNavView"
			Grid.Row="1"
			IsBackButtonVisible="Collapsed"
			IsSettingsVisible="False"
			AlwaysShowHeader="False"
			PaneDisplayMode="Left"
			OpenPaneLength="280"
			MenuItemsSource="{x:Bind ViewModel.ConfigPageViewModels}"
			SelectedItem="{x:Bind ViewModel.SelectedPageViewModel.Value, Mode=TwoWay}" >

			<!-- ナビゲーションメニュー項目のテンプレート -->
			<NavigationView.MenuItemTemplate>
				<DataTemplate x:DataType="config:IConfigPageViewModel" >
					<NavigationViewItem>
						<NavigationViewItem.Icon>
							<FontIcon Glyph="{Binding PageIconGlyph}" />
						</NavigationViewItem.Icon>
						<NavigationViewItem.Content>
							<StackPanel Spacing="2" >
								<TextBlock Text="{Binding PageName}"
									FontSize="14"
									FontWeight="SemiBold" />
								<TextBlock Text="{Binding PageDescription}"
									FontSize="11"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									TextTrimming="CharacterEllipsis" />
							</StackPanel>
						</NavigationViewItem.Content>
					</NavigationViewItem>
				</DataTemplate>
			</NavigationView.MenuItemTemplate>

			<!-- コンテンツ領域 -->
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>

				<!-- ページコンテンツ表示用の Frame -->
				<Frame x:Name="ContentFrame"
					Grid.Row="0" />

				<!-- フッター: 保存ボタン -->
				<Border Grid.Row="1"
					Padding="24,12"
					BorderThickness="0,1,0,0"
					BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" >
					<Grid>
						<Button HorizontalAlignment="Right"
							Style="{StaticResource AccentButtonStyle}"
							Command="{x:Bind ViewModel.SaveCommand}"
							MinWidth="120" >
							<StackPanel Orientation="Horizontal"
								Spacing="8" >
								<FontIcon Glyph="&#xE74E;"
									FontSize="14" />
								<TextBlock Text="保存" />
							</StackPanel>
						</Button>
					</Grid>
				</Border>
			</Grid>
		</NavigationView>
	</Grid>
</Window>