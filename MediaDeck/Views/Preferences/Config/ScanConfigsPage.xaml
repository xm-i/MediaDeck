<Page x:Class="MediaDeck.Views.Preferences.Config.ScanConfigPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:config="using:MediaDeck.ViewModels.Preferences.Config"
	mc:Ignorable="d"
	Background="Transparent"
	x:Name="PageRoot" >

	<Page.Resources>
		<!-- カードの背景ブラシ -->
		<SolidColorBrush x:Key="CardBackgroundBrush"
			Color="{ThemeResource CardBackgroundFillColorDefaultColor}" />
		<SolidColorBrush x:Key="CardBorderBrush"
			Color="{ThemeResource CardStrokeColorDefaultColor}" />
	</Page.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto" >
		<StackPanel Spacing="4"
			Padding="36,24,36,36"
			MaxWidth="800" >

			<!-- セクションヘッダー -->
			<StackPanel Spacing="4"
				Margin="0,0,0,16" >
				<TextBlock Text="対象拡張子"
					Style="{StaticResource BodyStrongTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
				<TextBlock Text="スキャン対象とするファイルの拡張子とメディアタイプを管理します。"
					Style="{StaticResource CaptionTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
			</StackPanel>

			<!-- 拡張子リスト -->
			<ItemsControl ItemsSource="{x:Bind ViewModel.TargetExtensions}" >
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="config:ExtensionConfigViewModel" >
						<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
							BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
							BorderThickness="1"
							CornerRadius="4"
							Padding="16,10,12,10"
							Margin="0,0,0,2" >
							<Grid ColumnDefinitions="Auto,Auto,*,Auto" >
								<!-- メディアタイプアイコン -->
								<FontIcon Grid.Column="0"
									Glyph="&#xE8A5;"
									FontSize="16"
									Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
									VerticalAlignment="Center"
									Margin="0,0,12,0" />

								<!-- メディアタイプ選択 -->
								<ComboBox Grid.Column="1"
									Width="130"
									VerticalAlignment="Center"
									ItemsSource="{x:Bind MediaTypeConditions}"
									SelectedItem="{x:Bind MediaType.Value, Mode=TwoWay}" />

								<!-- 拡張子入力 -->
								<TextBox Grid.Column="2"
									Margin="8,0,8,0"
									VerticalAlignment="Center"
									Text="{x:Bind Extension.Value, Mode=TwoWay}"
									PlaceholderText="例: .mp4" />

								<!-- 削除ボタン -->
								<Button Grid.Column="3"
									VerticalAlignment="Center"
									Command="{x:Bind RemoveCommand}"
									Style="{StaticResource SubtleButtonStyle}"
									ToolTipService.ToolTip="この拡張子を削除"
									Padding="6"
									BorderThickness="0" >
									<FontIcon Glyph="&#xE74D;"
										FontSize="14"
										Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
								</Button>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- 追加ボタン -->
			<Button Command="{x:Bind ViewModel.AddExtensionCommand}"
				HorizontalAlignment="Stretch"
				Margin="0,4,0,0"
				Padding="12"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				CornerRadius="4"
				HorizontalContentAlignment="Center" >
				<StackPanel Orientation="Horizontal"
					Spacing="8" >
					<FontIcon Glyph="&#xE710;"
						FontSize="14"
						Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
					<TextBlock Text="拡張子を追加"
						Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
						FontWeight="SemiBold" />
				</StackPanel>
			</Button>

		</StackPanel>
	</ScrollViewer>
</Page>