<Page x:Class="MediaDeck.Views.Preferences.Config.ExecutionConfigPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:config="using:MediaDeck.ViewModels.Preferences.Config"
	mc:Ignorable="d"
	Background="Transparent"
	x:Name="PageRoot" >

	<ScrollViewer VerticalScrollBarVisibility="Auto" >
		<StackPanel Spacing="4"
			Padding="36,24,36,36"
			MaxWidth="800" >

			<!-- セクションヘッダー -->
			<StackPanel Spacing="4"
				Margin="0,0,0,16" >
				<TextBlock Text="外部プログラム"
					Style="{StaticResource BodyStrongTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
				<TextBlock Text="メディアファイルを開く外部プログラムとその起動引数を設定します。"
					Style="{StaticResource CaptionTextBlockStyle}"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
			</StackPanel>

			<!-- プログラムリスト -->
			<ItemsControl ItemsSource="{x:Bind ViewModel.ExecutionPrograms}" >
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="config:ExecutionProgramConfigViewModel" >
						<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
							BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
							BorderThickness="1"
							CornerRadius="4"
							Padding="16,12"
							Margin="0,0,0,2" >
							<Grid RowDefinitions="Auto,Auto"
								ColumnDefinitions="*,Auto" >
								<!-- 上段: メディアタイプ選択 -->
								<StackPanel Grid.Row="0"
									Grid.Column="0"
									Orientation="Horizontal"
									Spacing="12"
									VerticalAlignment="Center" >
									<FontIcon Glyph="&#xE756;"
										FontSize="16"
										Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
										VerticalAlignment="Center" />
									<ComboBox Width="130"
										VerticalAlignment="Center"
										ItemsSource="{x:Bind MediaTypeConditions}"
										SelectedItem="{x:Bind MediaType.Value, Mode=TwoWay}" />
								</StackPanel>

								<!-- 削除ボタン -->
								<Button Grid.Row="0"
									Grid.Column="1"
									VerticalAlignment="Center"
									Command="{x:Bind RemoveCommand}"
									Style="{StaticResource SubtleButtonStyle}"
									ToolTipService.ToolTip="このプログラムを削除"
									Padding="6"
									BorderThickness="0" >
									<FontIcon Glyph="&#xE74D;"
										FontSize="14"
										Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
								</Button>

								<!-- 下段: パスと引数 -->
								<Grid Grid.Row="1"
									Grid.Column="0"
									Grid.ColumnSpan="2"
									Margin="0,10,0,0"
									ColumnDefinitions="*,Auto" >
									<!-- パス入力 -->
									<TextBox Grid.Column="0"
										Margin="0,0,8,0"
										Text="{x:Bind Path.Value, Mode=TwoWay}"
										PlaceholderText="C:\Programs\MPC-BE\mpc-be64.exe"
										Header="実行ファイルパス" />

									<!-- 引数入力 -->
									<TextBox Grid.Column="1"
										Width="200"
										Text="{x:Bind Args.Value, Mode=TwoWay}"
										PlaceholderText="/fullscreen"
										Header="起動引数" />
								</Grid>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- 追加ボタン -->
			<Button Command="{x:Bind ViewModel.AddExecutionProgramCommand}"
				HorizontalAlignment="Stretch"
				Margin="0,4,0,0"
				Padding="12"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				CornerRadius="4"
				HorizontalContentAlignment="Center" >
				<StackPanel Orientation="Horizontal"
					Spacing="8" >
					<FontIcon Glyph="&#xE710;"
						FontSize="14"
						Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
					<TextBlock Text="プログラムを追加"
						Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
						FontWeight="SemiBold" />
				</StackPanel>
			</Button>

		</StackPanel>
	</ScrollViewer>
</Page>