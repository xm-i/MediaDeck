<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="MediaDeck.Views.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views"
	xmlns:localControls="using:MediaDeck.Views.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewerPanes="using:MediaDeck.Views.Panes.ViewerPanes"
	xmlns:filterPanes="using:MediaDeck.Views.Panes.FilterPanes"
	xmlns:sortPanes="using:MediaDeck.Views.Panes.SortPanes"
	xmlns:detailPanes="using:MediaDeck.Views.Panes.DetailPanes"
	xmlns:repositoryPanes="using:MediaDeck.Views.Panes.RepositoryPanes"
	xmlns:viewmodels="using:MediaDeck.ViewModels"
	xmlns:statusPanes="using:MediaDeck.Views.Panes.StatusPanes"
	mc:Ignorable="d"
	Title="MediaDeck">
	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop/>
	</Window.SystemBackdrop>
	<Grid Loaded="Window_Loaded"
		Background="Transparent" >
		<Grid.RowDefinitions>
			<RowDefinition Height="48" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- カスタムタイトルバー -->
		<Grid x:Name="AppTitleBar" Grid.Row="0"
			Background="{ThemeResource TitleBarBackgroundBrush}"
			Padding="0,0,188,0"
			VerticalAlignment="Stretch" >
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Image Source="/Assets/Square44x44Logo.scale-200.png"
					Width="16" Height="16"
					Margin="16,0,8,0" />
			</StackPanel>

			<!-- ナビゲーションメニュー（全タブ共通） -->
			<local:NavigationMenu Grid.Column="1"
				x:Name="NavigationMenuControl"
				Margin="12,0,0,0"
				HorizontalAlignment="Left"
				VerticalAlignment="Center"
				ViewModel="{x:Bind _viewModel.NavigationMenuViewModel}"/>
		</Grid>

		<!-- TabView -->
		<TabView Grid.Row="1"
			x:Name="MainTabView"
			VerticalAlignment="Stretch"
			IsAddTabButtonVisible="True"
			AddTabButtonCommand="{x:Bind _viewModel.AddTabCommand}"
			TabCloseRequested="MainTabView_TabCloseRequested"
			SelectionChanged="MainTabView_SelectionChanged"
			TabWidthMode="SizeToContent"
			TabItemsSource="{x:Bind _viewModel.Tabs}"
			Style="{StaticResource ModernTabViewStyle}">
			<TabView.TabItemTemplate>
				<DataTemplate x:DataType="viewmodels:TabContext">
					<TabViewItem KeyDown="TabViewItem_KeyDown" Style="{StaticResource ModernTabViewItemStyle}">
						<TabViewItem.Header>
							<Grid Background="Transparent" DoubleTapped="TabHeader_DoubleTapped">
								<TextBlock Text="{x:Bind DisplayName.Value, Mode=OneWay}" />
							</Grid>
						</TabViewItem.Header>
						<Grid Padding="2">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="250" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="250" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="*" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="*" />
							</Grid.RowDefinitions>
							<repositoryPanes:RepositorySelector Grid.Column="0" Grid.Row="0"
								ViewModel="{x:Bind RepositorySelectorViewModel, Mode=OneWay}" />
							<sortPanes:SortPane Grid.Column="0" Grid.Row="1"
								ViewModel="{x:Bind SortSelectorViewModel, Mode=OneWay}" />
							<filterPanes:FilterSelector Grid.Column="0" Grid.Row="2"
								ViewModel="{x:Bind FilterSelectorViewModel, Mode=OneWay}" />
							<viewerPanes:ViewerSelector Grid.Column="1" Grid.Row="0" Grid.RowSpan="3"
								ViewModel="{x:Bind ViewerSelectorViewModel, Mode=OneWay}" />
							<detailPanes:DetailSelector Grid.Column="2" Grid.Row="0" Grid.RowSpan="3"
								ViewModel="{x:Bind DetailSelectorViewModel, Mode=OneWay}" />
						</Grid>
					</TabViewItem>
				</DataTemplate>
			</TabView.TabItemTemplate>
			<TabView.TabStripFooter>
				<localControls:GlobalInfoBar
					VerticalAlignment="Center"
					HorizontalAlignment="Right"
					Margin="0,0,8,0" />
			</TabView.TabStripFooter>
		</TabView>

		<!-- ステータスバー -->
		<statusPanes:StatusBarPane Grid.Row="2"
			ViewModel="{x:Bind _viewModel.SelectedTab.Value.StatusBarViewModel, Mode=OneWay}" />

		<!-- ウィンドウのボーダー (活性状態に応じて色が変わる) -->
		<Border x:Name="RootBorder"
				Grid.RowSpan="3"
				BorderThickness="1"
				BorderBrush="Gray"
				IsHitTestVisible="False" />
	</Grid>
</Window>