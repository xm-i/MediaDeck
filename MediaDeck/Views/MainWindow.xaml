<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="MediaDeck.Views.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views"
	xmlns:localControls="using:MediaDeck.Views.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewerPanes="using:MediaDeck.Views.Panes.ViewerPanes"
	xmlns:filterPanes="using:MediaDeck.Views.Panes.FilterPanes"
	xmlns:detailPanes="using:MediaDeck.Views.Panes.DetailPanes"
	xmlns:repositoryPanes="using:MediaDeck.Views.Panes.RepositoryPanes"
	mc:Ignorable="d"
	Title="MediaDeck" >
	<Grid Loaded="Window_Loaded" >
		<Grid.RowDefinitions>
			<RowDefinition Height="auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- ナビゲーションメニュー（全タブ共通） -->
		<local:NavigationMenu Grid.Row="0"
			x:Name="NavigationMenuControl"
			DataContext="{x:Bind _viewModel.NavigationMenuViewModel}"/>

		<!-- TabView -->
		<TabView Grid.Row="1"
			x:Name="MainTabView"
			VerticalAlignment="Stretch"
			IsAddTabButtonVisible="True"
			AddTabButtonCommand="{x:Bind _viewModel.AddTabCommand}"
			TabCloseRequested="MainTabView_TabCloseRequested"
			SelectionChanged="MainTabView_SelectionChanged"
			TabWidthMode="SizeToContent"
			TabItemsSource="{x:Bind _viewModel.Tabs}">
			<TabView.TabItemTemplate>
				<DataTemplate>
					<TabViewItem Header="{Binding DisplayName.Value}" >
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="250" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="250" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="*" />
								<RowDefinition Height="*" />
							</Grid.RowDefinitions>
							<repositoryPanes:RepositorySelector Grid.Column="0" Grid.Row="0"
								DataContext="{Binding RepositorySelectorViewModel}" />
							<filterPanes:FilterSelector Grid.Column="0" Grid.Row="1"
								DataContext="{Binding FilterSelectorViewModel}" />
							<viewerPanes:ViewerSelector Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
								DataContext="{Binding ViewerSelectorViewModel}" />
							<detailPanes:DetailSelector Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
								DataContext="{Binding DetailSelectorViewModel}" />
						</Grid>
					</TabViewItem>
				</DataTemplate>
			</TabView.TabItemTemplate>
			<TabView.TabStripFooter>
				<localControls:GlobalInfoBar
					VerticalAlignment="Center"
					HorizontalAlignment="Right"
					Margin="0,0,8,0" />
			</TabView.TabStripFooter>
		</TabView>
	</Grid>
</Window>