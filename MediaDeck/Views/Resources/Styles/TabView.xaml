<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TabViewのタブアイテム用モダンスタイル -->
    <Style x:Key="ModernTabViewItemStyle" TargetType="TabViewItem">
        <!-- 角の丸みをゼロにし、シャープでプロフェッショナルな印象に -->
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="16,0,12,0" />
        
        <!-- 非選択時は背景を透過させ、アクリル背景を活かすことで一段暗く見せる -->
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        
        <!-- TabViewItemのControlTemplate再定義 -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabViewItem">
                    <Grid x:Name="LayoutRoot" Margin="{TemplateBinding Margin}">
                        
                        <!-- タブ背景（選択時はコンテンツ領域と一体化させる） -->
                        <Border x:Name="TabContainer"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- アイコン領域 -->
                                <ContentPresenter x:Name="IconBox"
                                                  Content="{TemplateBinding IconSource}"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Visibility="Collapsed" />

                                <!-- タブのヘッダーテキスト -->
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Grid.Column="1"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}" />

                                <!-- 閉じるボタン（シンプルデザイン化） -->
                                <Button x:Name="CloseButton"
                                        Grid.Column="2"
                                        Content="&#xE711;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="12"
                                        Width="28" Height="28"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="4,0,0,0"
                                        Padding="0"
                                        CornerRadius="4"
                                        Opacity="0"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="タブを閉じる" />
                            </Grid>
                        </Border>

                        <!-- 選択されているタブの上部に表示するアクセントカラーの細いライン -->
                        <Rectangle x:Name="TopAccentLine"
                                   VerticalAlignment="Top"
                                   Height="2"
                                   Fill="{ThemeResource SystemControlHighlightAccentBrush}"
                                   Opacity="0" />

                        <!-- VisualState によるインタラクションの定義 -->
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="TabContainer.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                        <Setter Target="CloseButton.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="TabContainer.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                        <Setter Target="CloseButton.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <!-- 選択時は下のコンテンツ領域と一体化させる背景色 -->
                                        <Setter Target="TabContainer.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                                        <Setter Target="TopAccentLine.Opacity" Value="1" />
                                        <Setter Target="CloseButton.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                
                                <VisualState x:Name="PointerOverSelected">
                                    <VisualState.Setters>
                                        <Setter Target="TabContainer.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                                        <Setter Target="TopAccentLine.Opacity" Value="1" />
                                        <Setter Target="CloseButton.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                
                                <VisualState x:Name="PressedSelected">
                                    <VisualState.Setters>
                                        <Setter Target="TabContainer.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                                        <Setter Target="TopAccentLine.Opacity" Value="0.8" />
                                        <Setter Target="CloseButton.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabView自体のスタイル（タブ領域とコンテンツ領域の境界をなくし一体感を出す） -->
    <Style x:Key="ModernTabViewStyle" TargetType="TabView">
        <Setter Property="Background" Value="Transparent" />
    </Style>
</ResourceDictionary>
