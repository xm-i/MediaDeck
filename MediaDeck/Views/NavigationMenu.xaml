<?xml version="1.0" encoding="utf-8" ?>
<local:NavigationMenuUserControl x:Class="MediaDeck.Views.NavigationMenu"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.Views"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:enum="using:MediaDeck.Composition.Enum"
	mc:Ignorable="d" >

	<Grid>
		<Grid.Resources>
			<Storyboard x:Name="NotificationPulseStoryboard"
				RepeatBehavior="Forever" >
				<DoubleAnimation Storyboard.TargetName="NotificationIconTransform"
					Storyboard.TargetProperty="ScaleX"
					From="1.0"
					To="1.2"
					Duration="0:0:0.5"
					AutoReverse="True" />
				<DoubleAnimation Storyboard.TargetName="NotificationIconTransform"
					Storyboard.TargetProperty="ScaleY"
					From="1.0"
					To="1.2"
					Duration="0:0:0.5"
					AutoReverse="True" />
			</Storyboard>
		</Grid.Resources>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<MenuBar Grid.Column="0" Style="{StaticResource TransparentMenuBarStyle}">
			<MenuBarItem Title="表示" >
				<ToggleMenuFlyoutItem Text="既定 (Windowsの設定)"
					IsChecked="{x:Bind ViewModel.CurrentTheme.Value, Mode=OneWay, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Default}"
					Click="ThemeMenuFlyoutItem_Click" Tag="Default" />
				<ToggleMenuFlyoutItem Text="ライト"
					IsChecked="{x:Bind ViewModel.CurrentTheme.Value, Mode=OneWay, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Light}"
					Click="ThemeMenuFlyoutItem_Click" Tag="Light" />
				<ToggleMenuFlyoutItem Text="ダーク"
					IsChecked="{x:Bind ViewModel.CurrentTheme.Value, Mode=OneWay, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Dark}"
					Click="ThemeMenuFlyoutItem_Click" Tag="Dark" />
			</MenuBarItem>
			<MenuBarItem Title="ツール" >
				<MenuFlyoutItem Text="タグ管理"
					Click="MenuFlyoutItem_Click"
					Tag="TagManager" />
				<MenuFlyoutItem Text="フォルダ管理"
					Click="MenuFlyoutItem_Click"
					Tag="FolderManager" />
				<MenuFlyoutSeparator />
				<MenuFlyoutItem Text="重複ファイル検索"
					Click="MenuFlyoutItem_Click"
					Tag="DuplicateDetector" />
				<MenuFlyoutSeparator />
				<MenuFlyoutItem Text="設定"
					Click="MenuFlyoutItem_Click"
					Tag="Config" />
				<MenuFlyoutSeparator />
				<MenuFlyoutItem Text="バックグラウンドタスク"
					Click="MenuFlyoutItem_Click"
					Tag="BackgroundTasks" />
			</MenuBarItem>
		</MenuBar>

		<Button Grid.Column="1"
			VerticalAlignment="Center"
			Margin="8,0"
			Padding="8,4"
			ToolTipService.ToolTip="未処理のファイル変更があります。"
			Click="SyncNotificationButton_Click"
			Visibility="{x:Bind ViewModel.HasUnprocessedChanges.Value, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
			Style="{ThemeResource AccentButtonStyle}" >
			<Button.Content>
				<Grid>
					<FontIcon FontFamily="Segoe Fluent Icons"
						Glyph="&#xE89A;" />
				</Grid>
			</Button.Content>
			<Button.RenderTransform>
				<ScaleTransform x:Name="NotificationIconTransform"
					CenterX="16"
					CenterY="16" />
			</Button.RenderTransform>
		</Button>
	</Grid>
</local:NavigationMenuUserControl>