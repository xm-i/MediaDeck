<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="MediaDeck.Views.Thumbnails.BulkThumbnailRegenerationWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="using:MediaDeck.Views.Thumbnails"
	xmlns:vm="using:MediaDeck.ViewModels.Thumbnails"
	mc:Ignorable="d"
	Title="サムネイル一括再生成" >
	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop/>
	</Window.SystemBackdrop>
	<Grid Background="Transparent"
		Loaded="Window_Loaded" >
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- カスタムタイトルバー -->
		<Grid x:Name="AppTitleBar" Grid.Row="0" Height="32"
			Background="{ThemeResource TitleBarBackgroundBrush}"
			Padding="12,0,0,0"
			VerticalAlignment="Top" >
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Image Source="/Assets/Square44x44Logo.scale-200.png" Width="16" Height="16" Margin="4,0,8,0" />
				<TextBlock Text="{x:Bind Title}" FontSize="12" VerticalAlignment="Center" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="1" >
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="320" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

		<!-- 左ペイン: 対象アイテム一覧 -->
		<Grid Grid.Column="0" Grid.Row="0" Padding="8" >
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<StackPanel Grid.Row="0" Spacing="4" >
				<TextBlock FontWeight="SemiBold" Text="対象ファイル" />
				<TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" >
					<Run Text="メディアタイプ: " />
					<Run Text="{x:Bind ViewModel.TargetMediaType.Value, Mode=OneWay}" />
				</TextBlock>
				<TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" >
					<Run Text="件数: " />
					<Run Text="{x:Bind ViewModel.TotalCount.Value, Mode=OneWay}" />
				</TextBlock>
			</StackPanel>
			<ListView Grid.Row="1"
				ItemsSource="{x:Bind ViewModel.Items}"
				SelectionMode="None" >
				<ListView.ItemTemplate>
					<DataTemplate x:DataType="vm:BulkThumbnailItemViewModel" >
						<Grid Padding="4" >
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
								Text="{x:Bind FilePath}"
								TextTrimming="CharacterEllipsis"
								ToolTipService.ToolTip="{x:Bind FilePath}" />
							<TextBlock Grid.Column="1" Margin="8,0,0,0"
								Text="{x:Bind StatusText.Value, Mode=OneWay}" />
						</Grid>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Grid>

		<!-- 右ペイン: メディアタイプ毎の設定 -->
		<Border Grid.Column="1" Grid.Row="0" BorderThickness="1,0,0,0" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" >
			<ContentControl
				HorizontalContentAlignment="Stretch"
				VerticalContentAlignment="Stretch"
				Content="{x:Bind ViewModel.ConfigViewModel.Value, Mode=OneWay}"
				ContentTemplateSelector="{StaticResource BulkThumbnailConfigTplSel}" />
		</Border>

		<!-- 下部: 進捗バー & 操作ボタン -->
		<Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Padding="8" >
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" >
				<ProgressBar
					Minimum="0"
					Maximum="{x:Bind ViewModel.TotalCount.Value, Mode=OneWay}"
					Value="{x:Bind ViewModel.CompletedCount.Value, Mode=OneWay}"
					IsIndeterminate="False" />
				<TextBlock>
					<Run Text="{x:Bind ViewModel.CompletedCount.Value, Mode=OneWay}" />
					<Run Text=" / " />
					<Run Text="{x:Bind ViewModel.TotalCount.Value, Mode=OneWay}" />
				</TextBlock>
			</StackPanel>
			<Button Grid.Column="1" Margin="8,0,0,0"
				Command="{x:Bind ViewModel.ExecuteCommand}" >
				<TextBlock Text="実行" />
			</Button>
			<Button Grid.Column="2" Margin="8,0,0,0"
				Command="{x:Bind ViewModel.CancelCommand}" >
				<TextBlock Text="中断" />
			</Button>
		</Grid>
	</Grid>
	</Grid>
</Window>
