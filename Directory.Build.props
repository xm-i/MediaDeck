<Project>
  <PropertyGroup>
    <Deterministic>true</Deterministic>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <AnalysisLevel>preview</AnalysisLevel>
  </PropertyGroup>
  <ItemGroup Condition="'$(ProjectName)' != 'MediaDeck.Analyzers' AND !$(ProjectName.EndsWith('.Tests'))">
    <ProjectReference Include="$(MSBuildThisFileDirectory)lib\MediaDeck.Analyzers\MediaDeck.Analyzers.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>