<?xml version="1.0" encoding="utf-8" ?>
<local:VideoThumbnailPickerViewUserControl
	x:Class="MediaDeck.MediaItemTypes.UI.Video.Views.VideoThumbnailPickerView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.MediaItemTypes.UI.Video.Views"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:controls="using:CommunityToolkit.WinUI.Controls"
	xmlns:flyleaf="using:FlyleafLib.Controls.WinUI"
	mc:Ignorable="d" >
	<UserControl.Resources>
		<flyleaf:TicksToTimeConverter x:Key="TicksToTime"/>
		<flyleaf:TicksToSecondsConverter x:Key="TicksToSeconds" />
	</UserControl.Resources>
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid Grid.Column="0"
			Grid.Row="0" >
			<Image
				Source="{x:Bind ViewModel.OriginalThumbnail.Value,Mode=OneWay,Converter={StaticResource BinaryToImageSourceConverter}}" />
		</Grid>
		<Grid Grid.Column="1"
			Grid.Row="0" >
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<Grid x:Name="playerRootGrid">
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<flyleaf:FlyleafHost x:Name="flyleafHost" Player="{x:Bind Player}"/>
				<Grid Grid.Row="1" VerticalAlignment="Bottom" Background="#1000">
					<Grid.RowDefinitions>
						<RowDefinition/>
						<RowDefinition/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="1" Margin="8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="auto"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel Orientation="Horizontal">
							<Button x:Name="btnPlayback" IsTabStop="False" Command="{x:Bind Player.Commands.TogglePlayPause}" IsEnabled="{x:Bind Player.CanPlay, Mode=OneWay}"/>
						</StackPanel>

						<Grid Margin="8,0,8,0" Grid.Column="1">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="auto"/>
							</Grid.ColumnDefinitions>

							<Slider IsTabStop="False" Grid.Column="0" Margin="10,0,10,0"
								VerticalAlignment="Center"
								IsThumbToolTipEnabled="False"
								Value="{Binding Player.CurTime, Mode=TwoWay, Converter={StaticResource TicksToSeconds}}"
								Maximum="{x:Bind Player.Duration, Mode=OneWay,Converter={StaticResource TicksToSeconds}}"/>

							<TextBlock Grid.Column="1"
								HorizontalAlignment="Left"
								VerticalAlignment="Center">
								<Run Text="{x:Bind Player.CurTime, Mode=OneWay, Converter={StaticResource TicksToTime}}"/>
								<Run Text=" / "/>
								<Run Text="{x:Bind Player.Duration, Mode=OneWay, Converter={StaticResource TicksToTime}}"/>
							</TextBlock>
						</Grid>

						<StackPanel Grid.Column="2" Orientation="Horizontal">
							<Slider IsTabStop="False" Maximum="100" Value="{x:Bind Player.Audio.Volume, Mode=TwoWay}" Width="100"/>
						</StackPanel>
					</Grid>
				</Grid>
			</Grid>

			<Image Grid.Row="1"
				Source="{x:Bind ViewModel.CandidateThumbnail.Value,Mode=OneWay,Converter={StaticResource BinaryToImageSourceConverter}}" />
		</Grid>
		<controls:DockPanel Grid.Column="0"
			Grid.ColumnSpan="2"
			Grid.Row="1" >
			<Button controls:DockPanel.Dock="Right"
				Command="{x:Bind ViewModel.RecreateThumbnailCommand}" >
				<TextBlock Text="Recreate" />
			</Button>
			<Button controls:DockPanel.Dock="Right"
				Command="{x:Bind ViewModel.PickThumbnailFromFileCommand}" >
				<TextBlock Text="Browse..." />
			</Button>
			<Button controls:DockPanel.Dock="Right"
				Command="{x:Bind ViewModel.SaveCommand}" >
				<TextBlock Text="Save" />
			</Button>
			<TextBox controls:DockPanel.Dock="Right"
				Text="{x:Bind ViewModel.Time.Value, Mode=TwoWay, Converter={StaticResource TimeSpanToStringConverter}}" />
			<Grid />
		</controls:DockPanel>
	</Grid>
</local:VideoThumbnailPickerViewUserControl>