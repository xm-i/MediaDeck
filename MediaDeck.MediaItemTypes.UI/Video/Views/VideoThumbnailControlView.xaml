<?xml version="1.0" encoding="utf-8" ?>
<local:VideoThumbnailControlViewUserControl
    x:Class="MediaDeck.MediaItemTypes.UI.Video.Views.VideoThumbnailControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MediaDeck.MediaItemTypes.UI.Video.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" >
    <Grid>
        <Image Source="{x:Bind ViewModel.ThumbnailFilePath.Value, Mode=OneWay}" Stretch="Uniform" />

        <!-- 拡張子バッジ (右上) -->
        <Border Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
            CornerRadius="0,0,0,4" Padding="5,2"
            HorizontalAlignment="Right" VerticalAlignment="Top" >
            <StackPanel Orientation="Horizontal" Spacing="4" >
                <FontIcon Glyph="&#xE714;"
                    FontSize="10" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{x:Bind ViewModel.FilePath, Converter={StaticResource FilePathToExtensionConverter}}"
                    FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Border>

        <!-- 再生時間 (右下) -->
        <Border Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
            CornerRadius="4,0,0,0" Padding="5,2"
            HorizontalAlignment="Right" VerticalAlignment="Bottom" >
            <TextBlock Text="{x:Bind CastedViewModel.Duration, Converter={StaticResource DurationToStringConverter}}"
                FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Border>
    </Grid>
</local:VideoThumbnailControlViewUserControl>

