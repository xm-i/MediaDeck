<?xml version="1.0" encoding="utf-8" ?>
<local:FolderGroupThumbnailPickerViewUserControl
	x:Class="MediaDeck.MediaItemTypes.UI.FolderGroup.Views.FolderGroupThumbnailPickerView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:MediaDeck.MediaItemTypes.UI.FolderGroup.Views"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:MediaDeck.Composition.Interfaces.MediaItemTypes.ViewModels"
	xmlns:controls="using:CommunityToolkit.WinUI.Controls"
	mc:Ignorable="d">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid Grid.Column="0"
			Grid.Row="0"
			Grid.RowSpan="2"
			Margin="8">
			<Image Source="{x:Bind ViewModel.OriginalThumbnail.Value, Mode=OneWay, Converter={StaticResource BinaryToImageSourceConverter}}"/>
		</Grid>

		<ListView Grid.Column="1"
			Grid.Row="0"
			ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
			SelectedItem="{x:Bind ViewModel.SelectedItem.Value, Mode=TwoWay}"
			SelectionMode="Single"
			Margin="8">
			<ListView.ItemTemplate>
				<DataTemplate x:DataType="vm:IMediaItemViewModel">
					<StackPanel Orientation="Horizontal" Padding="4">
						<Image Source="{x:Bind ThumbnailFilePath.Value, Mode=OneWay}" Width="40" Height="40" Stretch="UniformToFill" Margin="0,0,8,0" />
						<TextBlock Text="{x:Bind FilePath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
					</StackPanel>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>

		<Grid Grid.Column="1"
			Grid.Row="1"
			Margin="8">
			<Image Source="{x:Bind ViewModel.CandidateThumbnail.Value, Mode=OneWay, Converter={StaticResource BinaryToImageSourceConverter}}"/>
		</Grid>

		<controls:DockPanel Grid.Column="0"
			Grid.ColumnSpan="2"
			Grid.Row="2"
			Padding="8">
			<Button controls:DockPanel.Dock="Right"
				Command="{x:Bind ViewModel.RecreateThumbnailCommand}">
				<TextBlock Text="Recreate" />
			</Button>
			<Button controls:DockPanel.Dock="Right"
				Command="{x:Bind ViewModel.PickThumbnailFromFileCommand}">
				<TextBlock Text="Browse..." />
			</Button>
			<Button controls:DockPanel.Dock="Right"
				Command="{x:Bind ViewModel.SaveCommand}">
				<TextBlock Text="Save" />
			</Button>
			<Grid />
		</controls:DockPanel>
	</Grid>
</local:FolderGroupThumbnailPickerViewUserControl>
